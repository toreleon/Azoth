ANTHROPIC_API_KEY=sk-ant-...

# ---- Optional: point the SDK at any Anthropic-compatible endpoint --------
# The Claude Agent SDK reads ANTHROPIC_BASE_URL / ANTHROPIC_API_KEY from env.
# Any provider that exposes an Anthropic-compatible /v1/messages API works
# (no proxy needed). Examples:
#   Zhipu GLM:  ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
#               ANTHROPIC_API_KEY=<zhipu key>
#               and set model: glm-4.6 (or similar) in src/config/config.yaml
ANTHROPIC_BASE_URL=

# Path to SQLite db (defaults to ~/.azoth/azoth.db)
# VNSTOCK_DB=/absolute/path/to/azoth.db

# Override config path (defaults to ~/.azoth/config.yaml)
# VNSTOCK_CONFIG=/absolute/path/to/config.yaml

# ---- Live broker (Phase 5) -----------------------------------------------
# Required when src/config/config.yaml has `broker: dnse`.
# Get DNSE_LOAN_PACKAGE_ID from /margin-service/loan-products after first
# successful login — values like 1372 are user-specific and will differ.
DNSE_USERNAME=
DNSE_PASSWORD=
DNSE_ACCOUNT_NO=
DNSE_LOAN_PACKAGE_ID=

# Top-level arming flag for real-money trading. Even with broker=dnse,
# placeOrder is refused unless this is set to "1". Keep it unset until you
# have round-tripped the credentials with read-only calls (snapshot, list).
VNSTOCK_LIVE_TRADING=
