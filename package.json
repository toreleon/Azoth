{
  "name": "@toreleon/azoth",
  "version": "0.0.1",
  "description": "Professional agent CLI for Vietnam equity research, portfolio workflow, and broker-aware trading operations",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toreleon/Azoth.git"
  },
  "bugs": {
    "url": "https://github.com/toreleon/Azoth/issues"
  },
  "homepage": "https://github.com/toreleon/Azoth#readme",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "azoth": "./dist/src/cli/azoth.js",
    "azoth-init": "./dist/src/cli/azoth-init.js",
    "azoth-analyze": "./dist/src/cli/analyze.js",
    "azoth-team": "./dist/src/cli/team.js",
    "azoth-backtest": "./dist/src/cli/agent-backtest.js"
  },
  "files": [
    "dist/src",
    "assets",
    "docs/releases",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "azoth": "tsx src/cli/azoth.tsx",
    "azoth:init": "tsx src/cli/azoth-init.ts",
    "analyze": "tsx src/cli/analyze.ts",
    "team": "tsx src/cli/team.ts",
    "team:chat": "tsx src/cli/team.ts",
    "backtest": "tsx src/cli/agent-backtest.ts",
    "build": "tsc -p tsconfig.json",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "prepack": "pnpm build",
    "release": "pnpm build && pnpm publish --access public --provenance",
    "start": "node dist/src/cli/azoth.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "better-sqlite3": "^11.5.0",
    "cheerio": "^1.0.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "technicalindicators": "^3.1.0",
    "undici": "^6.20.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
